CHRONO_DATABASE_URL=postgresql+asyncpg://chrono:chrono@127.0.0.1:5432/chronovita
CHRONO_REDIS_URL=redis://127.0.0.1:6379/0
CHRONO_CHROMA_URL=http://127.0.0.1:8001
CHRONO_DEBUG=true

# LLM 接入（默认 mock，无需配置；切换为以下三种之一启用真模型）
