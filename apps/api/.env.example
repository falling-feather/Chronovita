CHRONO_DEBUG=true
# CHRONO_SQLITE_PATH=../../data/chronovita.db

# LLM 适配层
# provider 可选：mock / deepseek
CHRONO_LLM_PROVIDER=mock
CHRONO_DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
CHRONO_DEEPSEEK_BASE_URL=https://api.deepseek.com
CHRONO_DEEPSEEK_MODEL=deepseek-v4-flash
# thinking 可选：disabled（默认，速度快）/ enabled（带推理，慢）
CHRONO_DEEPSEEK_THINKING=disabled
